#!/bin/sh

set -eu

if [ ! -f "mise.toml" ]; then
  printf '%s\n' "Run activation from the repository root." >&2
  exit 1
fi

REGRESSION_SURGEON_ROOT=$PWD
export REGRESSION_SURGEON_ROOT
if [ -z "${REGRESSION_SURGEON_USER_MISE_CONFIG:-}" ]; then
  if [ -n "${MISE_CONFIG_DIR:-}" ]; then
    REGRESSION_SURGEON_USER_MISE_CONFIG="$MISE_CONFIG_DIR/config.toml"
  elif [ -n "${XDG_CONFIG_HOME:-}" ]; then
    REGRESSION_SURGEON_USER_MISE_CONFIG="$XDG_CONFIG_HOME/mise/config.toml"
  else
    REGRESSION_SURGEON_USER_MISE_CONFIG="$HOME/.config/mise/config.toml"
  fi
  export REGRESSION_SURGEON_USER_MISE_CONFIG
fi
export MISE_INSTALL_PATH="$REGRESSION_SURGEON_ROOT/.local/bin/mise"
export MISE_DATA_DIR="$REGRESSION_SURGEON_ROOT/.local/share/mise"
export MISE_CACHE_DIR="$REGRESSION_SURGEON_ROOT/.local/cache/mise"
export MISE_STATE_DIR="$REGRESSION_SURGEON_ROOT/.local/state/mise"
export MISE_GLOBAL_CONFIG_FILE="$REGRESSION_SURGEON_ROOT/.local/mise-global.toml"
export MISE_CONFIG_DIR="$REGRESSION_SURGEON_ROOT/.local/config/mise"
case ":${MISE_IGNORED_CONFIG_PATHS:-}:" in
  *":$REGRESSION_SURGEON_USER_MISE_CONFIG:"*) ;;
  *) export MISE_IGNORED_CONFIG_PATHS="$REGRESSION_SURGEON_USER_MISE_CONFIG${MISE_IGNORED_CONFIG_PATHS:+:$MISE_IGNORED_CONFIG_PATHS}" ;;
esac

if [ ! -x "$MISE_INSTALL_PATH" ]; then
  printf '%s\n' "The repository-local toolchain is missing; run ./scripts/bootstrap first." >&2
  exit 1
fi

case ":$PATH:" in
  *":$(dirname "$MISE_INSTALL_PATH"):"*) ;;
  *) PATH="$(dirname "$MISE_INSTALL_PATH"):$PATH" ;;
esac
case ":$PATH:" in
  *":$MISE_DATA_DIR/shims:"*) ;;
  *) PATH="$MISE_DATA_DIR/shims:$PATH" ;;
esac
export PATH
REGRESSION_SURGEON_MISE_ACTIVE=project
export REGRESSION_SURGEON_MISE_ACTIVE

if [ "$#" -gt 0 ]; then
  exec "$@"
fi

exec "${SHELL:-/bin/sh}"
