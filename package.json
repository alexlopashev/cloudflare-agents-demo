{
  "name": "cloudflare-agents-demo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": "24.18.0",
    "pnpm": "10.34.5"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "dev": "node scripts/dev.mjs",
    "doctor": "node scripts/doctor.mjs",
    "e2e": "node --test tests/foundation/*.test.mjs",
    "format": "biome format --write . && markdownlint-cli2 --fix '**/*.md' '#node_modules' '#.local'",
    "format:check": "biome format . && markdownlint-cli2 '**/*.md' '#node_modules' '#.local'",
    "lint": "biome lint . && node scripts/lint-shells.mjs",
    "test": "node --test tests/**/*.test.mjs",
    "test:watch": "node --test --watch tests/**/*.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/node": "24.12.4",
    "markdownlint-cli2": "0.23.0",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
