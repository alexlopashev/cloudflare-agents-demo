{
  "name": "cloudflare-agents-demo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": "24.18.0",
    "pnpm": "10.34.5"
  },
  "dependencies": {
    "@ai-sdk/provider": "3.0.14",
    "@cloudflare/ai-chat": "0.9.3",
    "@cloudflare/think": "0.12.1",
    "agents": "0.17.3",
    "ai": "6.0.224",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "catalog:",
    "remark-gfm": "catalog:",
    "workers-ai-provider": "3.3.1",
    "zod": "4.4.3"
  },
  "scripts": {
    "build": "vite build && wrangler deploy --dry-run --config wrangler.live.jsonc --outdir .local/live-bundle && node scripts/assert-live-bundle.ts .local/live-bundle apps/web/dist/client",
    "check": "pnpm doctor && pnpm container:check && pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm e2e && pnpm build",
    "container:check": "docker-cli-plugin-docker-compose --file compose.yaml config --quiet",
    "db:migrate:local": "CI=1 wrangler d1 migrations apply regression-surgeon-telemetry --local --config wrangler.jsonc",
    "dev": "pnpm db:migrate:local && vite dev",
    "dev:live": "pnpm db:migrate:local && pnpm build && wrangler dev --config wrangler.live.jsonc",
    "ai:gateway:ensure": "node scripts/deploy.ts gateway",
    "deploy": "node scripts/deploy.ts deploy",
    "deploy:refresh": "node scripts/deploy.ts refresh",
    "deploy:reset": "node scripts/deploy.ts reset",
    "deploy:smoke": "node scripts/deploy.ts smoke",
    "deploy:writes:disable": "node scripts/deploy.ts disable-writes",
    "deploy:writes:enable": "node scripts/deploy.ts enable-writes",
    "doctor": "node scripts/doctor.ts",
    "e2e": "pnpm db:migrate:local && node scripts/e2e.ts && node scripts/scenario.ts reseed && node scripts/agent-e2e.ts",
    "format": "biome format --write . && markdownlint-cli2 --fix '**/*.md' '#node_modules' '#.local'",
    "format:check": "biome format . && markdownlint-cli2 '**/*.md' '#node_modules' '#.local'",
    "lint": "biome lint . && node scripts/lint-shells.ts",
    "scenario:reseed": "pnpm db:migrate:local && node scripts/scenario.ts reseed",
    "scenario:reset": "pnpm db:migrate:local && node scripts/scenario.ts reset",
    "test": "node scripts/test.ts",
    "test:foundation": "node --test tests/**/*.test.mjs",
    "test:platform": "vitest run --config vitest.config.ts && node scripts/run-worker-tests.ts",
    "test:watch": "node scripts/test.ts --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@cloudflare/vite-plugin": "1.44.0",
    "@cloudflare/vitest-pool-workers": "0.18.4",
    "@cloudflare/workers-types": "5.20260711.1",
    "@types/node": "24.12.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "markdownlint-cli2": "0.23.0",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "wrangler": "4.110.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ],
    "ignoredBuiltDependencies": [
      "@mongodb-js/zstd",
      "core-js-pure",
      "node-liblzma"
    ],
    "allowedDeprecatedVersions": {
      "prebuild-install": "7.1.3"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "@cloudflare/workers-types": "5"
      }
    }
  }
}
